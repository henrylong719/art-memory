{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"baseUrl": "./src",
		"paths": {
			"@/*": ["*"],
			"@generated/*": ["../generated/*"]
		},
		"moduleResolution": "bundler",
		"outDir": "dist",
		"importsNotUsedAsValues": "remove",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"types": ["node"],
	},
	"include": ["src/**/*"],
	"exclude": [
		"node_modules",
		"src/**/__tests__",
		"src/**/__tests__/**",
		"src/**/*.test.ts",
		"src/**/*.spec.ts"
	]
}
